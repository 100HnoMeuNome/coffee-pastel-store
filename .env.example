# Copy this file to .env and fill in your values
# docker compose automatically reads .env

# Datadog
DD_API_KEY=
DD_APP_KEY=                  # your Datadog application key (required for AI Guard)
DD_SITE=datadoghq.com          # or datadoghq.eu / us3.datadoghq.com / etc.

# Datadog AI Guard
DD_AI_GUARD_ENABLED=true

# Anthropic (for the AI Barista feature)
ANTHROPIC_API_KEY=

